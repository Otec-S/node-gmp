# Copy to .env for local development. .env is gitignored — never commit real secrets.
# The password below matches the local Podman/Compose Postgres only; use strong,
# unique secrets in staging and production, supplied via the environment or a secrets manager.
DATABASE_URL=postgresql://node_gmp:password123@localhost:5432/node_gmp
# psql inside the running container (official client, no local install needed):
#   podman exec -it node-gmp-db psql -U node_gmp -d node_gmp
# From the host (if psql is installed): psql postgresql://node_gmp:password123@localhost:5432/node_gmp
